{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "PowerToys Deck",
  "Version": "0.1.0.0",
  "Author": "ChromuSx",
  "Description": "Launch Microsoft PowerToys utilities, Run aliases, Command Palette shortcuts, and Keyboard Manager mappings from Stream Deck with automatic synchronization.",
  "URL": "https://github.com/ChromuSx/PowerToysDeck",
  "SupportURL": "https://github.com/ChromuSx/PowerToysDeck/issues",
  "Icon": "imgs/plugin-icon",
  "CodePath": "bin/plugin.js",
  "PropertyInspectorPath": "ui/property-inspector.html",
  "SDKVersion": 3,
  "Nodejs": {
    "Version": "20"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Software": {
    "MinimumVersion": "6.9"
  },
  "UUID": "com.chromusx.powertoys-deck",
  "Category": "PowerToys Deck",
  "CategoryIcon": "imgs/category-icon",
  "Actions": [
    {
      "Name": "PowerToys Command",
      "UUID": "com.chromusx.powertoys-deck.command",
      "Icon": "imgs/action-icon",
      "Tooltip": "Launch a PowerToys action synchronized from local PowerToys settings",
      "States": [
        {
          "Image": "imgs/key-idle",
          "Name": "Ready"
        },
        {
          "Image": "imgs/key-success",
          "Name": "Success"
        },
        {
          "Image": "imgs/key-error",
          "Name": "Error"
        }
      ],
      "DisableAutomaticStates": true,
      "PropertyInspectorPath": "ui/property-inspector.html",
      "SupportedInMultiActions": true,
      "UserTitleEnabled": false
    }
  ]
}
